# A scan site described entirely by CSS selectors — no code needed.
# Rename to <site>.toml to activate. Selector syntax: `css selector[@attr]`;
# without @attr the element text is used, `@href` alone reads the attribute
# off the matched item itself. Relative URLs resolve against the page.
#
# This example matches the common Madara WordPress theme layout used by
# many scan sites; adjust selectors per site (inspect with browser devtools).

id = "example-scans"
name = "Example Scans"
base_url = "https://example-scans.com"
min_delay_ms = 800            # politeness delay between requests
# referer = "https://example-scans.com/"   # some sites require it for images

[search]
url = "{base}/?s={query}&post_type=wp-manga"
item = ".c-tabs-item__content"
title = ".post-title a"
link = ".post-title a@href"
cover = "img@data-src"

# Optional query-less catalog listings for the Browse tab. `{page}` is the
# 1-based page number (omit it for single-page listings). Result selectors
# (item/title/link/cover) default to the [search] ones — override any that
# differ on the listing pages.
[browse.popular]
url = "{base}/manga/?m_orderby=views&page={page}"

[browse.latest]
url = "{base}/manga/?m_orderby=latest&page={page}"

[manga]
title = ".post-title h1"
description = ".description-summary p"
cover = ".summary_image img@data-src"
chapter_item = "li.wp-manga-chapter"
chapter_link = "a@href"
# chapter_number_regex = "(?i)ch(?:apter)?\\.?\\s*(\\d+(?:\\.\\d+)?)"  # default
# chapter_order = "newest_first"   # or "oldest_first"; only affects chapters
#                                  # whose number can't be parsed

[pages]
image = ".reading-content img@data-src"
