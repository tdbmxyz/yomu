{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yomu",
  "version": "1.2.0",
  "identifier": "xyz.tdbm.yomu",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "trunk build --release --dist ../yomu-web/dist ../yomu-web/index.html",
    "frontendDist": "../yomu-web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
