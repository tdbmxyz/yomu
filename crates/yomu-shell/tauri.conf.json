{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yomu",
  "version": "1.7.2",
  "identifier": "xyz.tdbm.yomu",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd $(git rev-parse --show-toplevel)/crates/yomu-web && trunk build --release",
    "frontendDist": "../yomu-web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
