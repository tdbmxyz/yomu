<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. The window background matches the web UI
         background (#14161c) so the inset padding around the webview blends
         in, and the status bar keeps light icons on the dark background. -->
    <style name="Theme.yomu_shell" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#FF14161C</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
